# Robinhood L2 RPC + chain config
RPC_URL=https://poptye-always-win.poptyedev.com/
CHAIN_ID=4663
EXPLORER_URL=https://so-explorer.poptyedev.com

# Quote token used to price other tokens (WETH on this chain, detected on-chain)
WETH_ADDRESS=0x0bd7d308f8e1639fab988df18a8011f41eacad73

# Optional: ETH/USD price to also show market cap & volume in USD.
# Leave empty to show values only in the quote token (ETH).
ETH_USD=

# Local web server port
PORT=3000
